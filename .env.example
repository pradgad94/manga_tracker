# --- App ---
APP_NAME="Manga Tracker API"
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1

# --- Security / JWT ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
JWT_ALGORITHM=HS256

# --- Database (PostgreSQL + pgvector) ---
DATABASE_URL=postgresql+asyncpg://manga:manga@localhost:5432/manga_tracker
DATABASE_ECHO=false

# --- Redis (optional caching) ---
REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600

# --- MyAnimeList (single-user sync) ---
# Create a client at https://myanimelist.net/apiconfig
MAL_CLIENT_ID=your-mal-client-id
MAL_CLIENT_SECRET=your-mal-client-secret
# Your own MAL username — this backend syncs only this account's list
MAL_USERNAME=your-mal-username
# Populated by the one-time OAuth helper script (scripts/mal_auth.py)
MAL_ACCESS_TOKEN=
MAL_REFRESH_TOKEN=

# --- Google Gemini (LLM provider: text generation + embeddings) ---
# https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-3.5-flash
# minimal | low | medium | high — how hard the model thinks before responding
GEMINI_THINKING_LEVEL=high

# --- Embeddings provider ---
# Gemini has a first-party embeddings endpoint, so the same API key and SDK
# cover both generation and embeddings — no separate vendor needed (unlike Claude,
# which has no embeddings endpoint of its own). Still behind an EmbeddingProvider
# interface so a different backend could be swapped in later if needed.
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSIONS=1536
